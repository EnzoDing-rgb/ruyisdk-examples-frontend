---
import type { GetStaticPaths } from "astro";

import Layout from "../../layouts/Layout.astro";
import { getBoardsForSocUrlSlug, getUniqueSocUrlSlugs, slugifyUrlSegment } from "../../lib/data";

export const getStaticPaths: GetStaticPaths = () =>
  getUniqueSocUrlSlugs().map(({ slug }) => ({ params: { soc: slug } }));

const socParam = Astro.params.soc!;
const boards = getBoardsForSocUrlSlug(socParam);

if (boards.length === 0) {
  return Astro.redirect("/vendors/");
}

// 需求：点击 SoC 也显示芯片厂商页面
const sv = boards[0]!.socVendor ?? "Unknown";
const svSlug = slugifyUrlSegment(sv);
---

<Layout title={`${sv} — 芯片厂商 — RuyiSDK Examples`}>
  {Astro.redirect(`/vendors/${encodeURIComponent(svSlug)}/`)}
</Layout>

---
import type { GetStaticPaths } from "astro";

import Layout from "../../layouts/Layout.astro";
import {
  getAllBoards,
  getBoardBySlug,
  getBoardReadmeBody,
  slugifyUrlSegment,
  socSlugFromCpu,
  stripDuplicateHeading,
} from "../../lib/data";
import { renderMarkdownToHtml } from "../../lib/renderMarkdown";
import { STATUS_LABEL_ZH } from "../../lib/status-labels";

export const getStaticPaths: GetStaticPaths = () =>
  getAllBoards().map((b) => ({ params: { board: b.slug } }));

const boardSlug = Astro.params.board!;
const board = getBoardBySlug(boardSlug);

if (!board) {
  return Astro.redirect("/");
}

const rawIntroMd = getBoardReadmeBody(board.slug, "zh") ?? "";
const introMd = rawIntroMd ? stripDuplicateHeading(rawIntroMd, board.product) : "";
const introHtml = introMd ? await renderMarkdownToHtml(introMd) : "";

const sv = board.socVendor ?? "Unknown";
const svSlug = slugifyUrlSegment(sv);
const socSlug = socSlugFromCpu(board.cpu);
---

<Layout title={`${board.product} — RuyiSDK Examples`}>
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
    <!-- Breadcrumb: 首页 / 芯片厂商 / SoC / 板子 -->
    <nav class="text-muted-foreground mb-6 flex flex-wrap items-center gap-x-1.5 text-sm">
      <a href="/" class="hover:text-foreground underline-offset-4 hover:underline">首页</a>
      <span class="select-none">/</span>
      <a href={`/vendors/${encodeURIComponent(svSlug)}/`} class="hover:text-foreground underline-offset-4 hover:underline">
        {sv}
      </a>
      {board.cpu && (
        <>
          <span class="select-none">/</span>
          <a
            href={`/socs/${encodeURIComponent(socSlug)}/`}
            class="hover:text-foreground underline-offset-4 hover:underline"
          >
            {board.cpu}
          </a>
        </>
      )}
      <span class="select-none">/</span>
      <span class="text-foreground font-medium">{board.product}</span>
    </nav>

    <!-- Board header + 属性（与 frontmatter 对齐） -->
    <header class="mb-8">
      <h1 class="text-foreground text-2xl font-semibold tracking-tight sm:text-3xl">{board.product}</h1>
      <dl class="text-muted-foreground mt-4 grid max-w-xl gap-x-6 gap-y-2 text-sm sm:grid-cols-2">
        <div class="flex flex-col gap-0.5">
          <dt class="text-muted-foreground/80 text-xs font-medium uppercase tracking-wide">product</dt>
          <dd class="text-foreground">{board.product}</dd>
        </div>
        <div class="flex flex-col gap-0.5">
          <dt class="text-muted-foreground/80 text-xs font-medium uppercase tracking-wide">cpu（SoC）</dt>
          <dd class="text-foreground">{board.cpu || "—"}</dd>
        </div>
        {
          board.cpuCore && (
            <div class="flex flex-col gap-0.5 sm:col-span-2">
              <dt class="text-muted-foreground/80 text-xs font-medium uppercase tracking-wide">cpu_core</dt>
              <dd class="text-foreground">{board.cpuCore}</dd>
            </div>
          )
        }
        {
          board.ram && (
            <div class="flex flex-col gap-0.5">
              <dt class="text-muted-foreground/80 text-xs font-medium uppercase tracking-wide">ram</dt>
              <dd class="text-foreground">{board.ram}</dd>
            </div>
          )
        }
        <div class="flex flex-col gap-0.5">
          <dt class="text-muted-foreground/80 text-xs font-medium uppercase tracking-wide">vendor（板厂）</dt>
          <dd class="text-foreground">{board.vendor || "—"}</dd>
        </div>
        <div class="flex flex-col gap-0.5">
          <dt class="text-muted-foreground/80 text-xs font-medium uppercase tracking-wide">soc_vendor</dt>
          <dd class="text-foreground">{board.socVendor ?? "—"}</dd>
        </div>
      </dl>
    </header>

    <!-- README intro -->
    {
      introHtml && (
        <article class="prose prose-slate dark:prose-invert mb-10 max-w-none" set:html={introHtml} />
      )
    }

    <!-- Divider -->
    <hr class="border-border mb-8" />

    <!-- Example list -->
    <section>
      <h2 class="text-foreground mb-4 text-lg font-semibold">示例列表</h2>
      {board.examples.length === 0 ? (
        <div class="text-muted-foreground rounded-xl border border-dashed p-10 text-center text-sm">
          暂无示例。
        </div>
      ) : (
        <div class="divide-border overflow-hidden rounded-xl border">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-muted/50 text-muted-foreground text-left text-xs">
                <th class="px-4 py-2.5 font-medium">示例名</th>
                <th class="px-4 py-2.5 font-medium">分类</th>
                <th class="hidden px-4 py-2.5 font-medium sm:table-cell">系统</th>
                <th class="hidden px-4 py-2.5 text-right font-medium sm:table-cell">更新日期</th>
              </tr>
            </thead>
            <tbody class="divide-border divide-y">
              {board.examples.map((ex) => (
                <tr class="hover:bg-muted/40 transition-colors">
                  <td class="px-4 py-3">
                    <a
                      href={`/boards/${encodeURIComponent(board.slug)}/${encodeURIComponent(ex.slug)}/`}
                      class="text-foreground font-medium hover:underline underline-offset-4"
                    >
                      {ex.title}
                    </a>
                  </td>
                  <td class="px-4 py-3">
                    <span class="bg-secondary text-secondary-foreground inline-block rounded-md px-2 py-0.5 text-xs">
                      {STATUS_LABEL_ZH[ex.status]}
                    </span>
                  </td>
                  <td class="text-muted-foreground hidden px-4 py-3 sm:table-cell">
                    {ex.sys ?? "—"}
                  </td>
                  <td class="text-muted-foreground hidden px-4 py-3 text-right sm:table-cell">
                    {ex.lastUpdate ?? "—"}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>
  </div>
</Layout>

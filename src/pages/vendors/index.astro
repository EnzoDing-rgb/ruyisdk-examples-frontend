---
import Layout from "../../layouts/Layout.astro";
import { getUniqueSiliconVendorUrlSlugs } from "../../lib/data";

const vendors = getUniqueSiliconVendorUrlSlugs();
---

<Layout title="芯片厂商 — RuyiSDK Examples">
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
    <nav class="text-muted-foreground mb-6 text-sm">
      <a href="/" class="hover:text-foreground underline-offset-4 hover:underline">首页</a>
      <span class="mx-1.5 select-none">/</span>
      <span class="text-foreground font-medium">芯片厂商</span>
    </nav>
    <h1 class="text-foreground mb-2 text-2xl font-semibold tracking-tight">芯片厂商</h1>
    <p class="text-muted-foreground mb-8 text-sm">按 Silicon Vendor（soc_vendor）浏览</p>
    <ul class="divide-border divide-y rounded-xl border">
      {
        vendors.map((v) => (
          <li>
            <a
              href={`/vendors/${encodeURIComponent(v.slug)}/`}
              class="hover:bg-muted/40 block px-4 py-3 text-base font-medium transition-colors"
            >
              {v.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Layout>
